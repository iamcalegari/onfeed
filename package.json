{
  "name": "recipes-on-demand",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "worker:import": "tsx --env-file=.env src/workers/import-worker.ts",
    "import:test": "YOUTUBE_DL_DIR=/usr/bin tsx --env-file=.env src/scripts/test-import-local.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node --env-file=.env dist/server.js",
    "setup:db": "tsx --env-file=.env src/infra/database/setup.ts",
    "seed:ingredients": "tsx --env-file=.env src/infra/database/seed-ingredients.ts",
    "ingest:dataset": "tsx --env-file=.env src/scripts/ingest-dataset.ts",
    "seed:recipes": "tsx --env-file=.env src/scripts/seed-recipes.ts",
    "db:status": "tsx --env-file=.env src/scripts/db-status.ts",
    "reconcile:ingredients": "tsx --env-file=.env src/scripts/reconcile-ingredients.ts",
    "reconcile:llm": "tsx --env-file=.env src/scripts/reconcile-pendings-llm.ts",
    "migrate:quantities": "tsx --env-file=.env src/scripts/migrate-ingredient-quantities.ts",
    "migrate:drinks": "tsx --env-file=.env src/scripts/migrate-drinks-occasion.ts",
    "migrate:thumbnails": "tsx --env-file=.env src/scripts/migrate-thumbnail-urls.ts",
    "infer:dietary-tags": "tsx --env-file=.env src/scripts/infer-dietary-tags.ts",
    "db:bootstrap": "tsx --env-file=.env src/scripts/db-prepare.ts bootstrap",
    "db:migrate": "tsx --env-file=.env src/scripts/db-prepare.ts migrate",
    "db:sync": "tsx --env-file=.env src/scripts/db-prepare.ts sync",
    "s3:up": "docker compose up -d",
    "s3:down": "docker compose down",
    "typecheck": "tsc --noEmit",
    "test": "VITEST_EXCLUDE_INTEGRATION=true vitest run",
    "test:all": "vitest run",
    "build:lambda": "esbuild src/lambda/ingest-handler.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/lambda/handler.js --external:@aws-sdk/* --tsconfig=tsconfig.json",
    "deploy:lambda": "bash infra/scripts/deploy-lambda.sh",
    "setup:ssm": "bash infra/scripts/setup-ssm.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@aws-sdk/client-bedrock-runtime": "^3.1070.0",
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/client-sqs": "^3.1071.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
    "@clerk/fastify": "^3.1.37",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/sensible": "^6.0.2",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@iamcalegari/mongoat": "^1.0.34-alpha",
    "@sinclair/typebox": "^0.34.9",
    "csv-parse": "^7.0.0",
    "fastify": "^5.1.0",
    "groq-sdk": "^1.3.0",
    "mongodb": "^6.16.0",
    "openai": "^6.45.0",
    "p-queue": "^9.3.0",
    "sharp": "^0.35.1",
    "sqs-consumer": "^15.0.2",
    "youtube-dl-exec": "^3.1.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock": "^3.1070.0",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^22.10.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
