# --- MongoDB Atlas ---
# Use a URI do Atlas (com <username>/<password> que o mongoat substitui)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_USERNAME=app_user
MONGODB_PASSWORD=changeme
MONGODB_DB_NAME=recipes_on_demand

# --- Voyage AI (embeddings) ---
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
VOYAGE_DIMENSIONS=1024

# --- Anthropic (extração na ingestão + geração híbrida) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Thumbnails (opcional: Bedrock + S3 + CloudFront) ---
# Sem AWS_REGION + IMAGES_S3_BUCKET, o app usa o placeholder e não gera imagem.
# Credenciais AWS via cadeia padrão do SDK (env, perfil, ou IAM role).
AWS_REGION=
IMAGES_S3_BUCKET=
IMAGES_CDN_DOMAIN=
BEDROCK_IMAGE_MODEL=amazon.titan-image-generator-v2:0

# Dev local com MinIO (ver docker-compose.yml + `yarn s3:up`):
#   AWS_REGION=us-east-1
#   IMAGES_S3_BUCKET=recipes-local
#   IMAGES_S3_ENDPOINT=http://localhost:9000   # S3 emulado (path-style)
#   IMAGES_FAKE_GENERATOR=true                 # Bedrock não emula → PNG fake
#   AWS_ACCESS_KEY_ID=localtest                # = MINIO_ROOT_USER
#   AWS_SECRET_ACCESS_KEY=localtest123         # = MINIO_ROOT_PASSWORD
IMAGES_S3_ENDPOINT=
IMAGES_FAKE_GENERATOR=

# --- Auth (Clerk) ---
# Crie um app em https://dashboard.clerk.com e pegue as chaves.
# Sem CLERK_SECRET_KEY, a auth fica desabilitada (rotas protegidas dão 401).
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# --- HTTP ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# Origem(ns) do front permitida(s) no CORS (separadas por vírgula)
FRONTEND_ORIGIN=http://localhost:3001
